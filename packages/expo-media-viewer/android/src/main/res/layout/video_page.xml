<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!-- Thumbnail shown while video is loading -->
    <ImageView
        android:id="@+id/video_thumbnail"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitCenter"
        android:contentDescription="Video thumbnail" />

    <!--
        PlayerView MUST use surface_type="texture_view" to avoid SurfaceView
        transparency/compositing issues that cause video frames to appear transparent
        when composited over other views (e.g. the React Native background).
    -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/video_player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:surface_type="texture_view"
        app:use_controller="true"
        app:show_timeout="3000"
        app:resize_mode="fit" />

    <!-- Loading spinner centered over the video -->
    <ProgressBar
        android:id="@+id/video_loading"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="center"
        android:indeterminateTint="@android:color/white"
        android:visibility="visible" />

</FrameLayout>
